

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexStock - Ultimate Dev Suite</title>
    
    <link rel="preconnect" href="https://pixabay.com">
    <link rel="preconnect" href="https://images.pexels.com">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-color: #ffffff;
            --text-main: #111;
            --pixabay-color: #27ae60;
            --pexels-color: #05a081;
            --ai-color: #6c5ce7;
            --radius: 12px;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            overflow-x: hidden;
        }

        /* --- NAVBAR --- */
        .navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #f0f0f0;
            padding: 14px 0;
            z-index: 1040;
        }
        .navbar-brand { font-weight: 800; letter-spacing: -0.5px; font-size: 1.4rem; }
        
        .nav-pills-custom {
            background: #f5f5f5;
            padding: 4px;
            border-radius: 30px;
            display: inline-flex;
        }
        .nav-btn {
            border: none;
            background: transparent;
            padding: 6px 20px;
            border-radius: 25px;
            font-size: 0.9rem;
            font-weight: 600;
            color: #666;
            transition: 0.2s;
        }
        .nav-btn.active {
            background: #000;
            color: white;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        /* --- LOADING OVERLAY (New) --- */
        #proLoader {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(5px);
            z-index: 2000;
            display: flex; flex-direction: column;
            justify-content: center; align-items: center;
        }
        .progress-bar-container {
            width: 300px; height: 6px; background: #eee; border-radius: 10px; margin-top: 20px; overflow: hidden;
        }
        .progress-fill {
            height: 100%; background: var(--ai-color); width: 0%; transition: width 0.2s;
        }

        /* --- GRID --- */
        .masonry-grid {
            column-count: 3; column-gap: 20px; padding: 20px 40px;
        }
        @media (max-width: 1024px) { .masonry-grid { column-count: 2; padding: 20px; } }
        @media (max-width: 600px) { .masonry-grid { column-count: 1; } }

        /* --- CARDS & SMOOTH FADE --- */
        .media-card {
            break-inside: avoid; margin-bottom: 20px; position: relative;
            border-radius: var(--radius); overflow: hidden; background: #f8f9fa;
            transform: translateZ(0); cursor: zoom-in;
            border: 2px solid transparent;
            min-height: 200px;
        }
        .media-card[data-source="Pixabay"]:hover { border-color: var(--pixabay-color); }
        .media-card[data-source="Pexels"]:hover { border-color: var(--pexels-color); }
        .media-card[data-source="AI"]:hover { border-color: var(--ai-color); }

        .media-content, .video-player { 
            width: 100%; display: block; object-fit: cover;
            opacity: 0; transition: opacity 0.8s ease-out; 
        }
        .loaded { opacity: 1 !important; }

        .source-badge {
            position: absolute; top: 12px; left: 12px;
            font-size: 0.7rem; font-weight: 800; padding: 4px 8px;
            border-radius: 4px; z-index: 6; text-transform: uppercase;
            background: white; letter-spacing: 0.5px;
        }
        .badge-pixabay { color: var(--pixabay-color); }
        .badge-pexels { color: var(--pexels-color); }
        .badge-ai { color: var(--ai-color); }

        .meta-layer {
            position: absolute; bottom: 0; left: 0; right: 0;
            padding: 50px 15px 15px;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            display: flex; justify-content: space-between; align-items: flex-end;
            opacity: 0; transition: opacity 0.2s; z-index: 10;
        }
        .media-card:hover .meta-layer { opacity: 1; }

        /* --- SKELETONS --- */
        .skeleton-card {
            background: #e0e0e0; border-radius: var(--radius);
            margin-bottom: 24px; height: 280px; position: relative; overflow: hidden;
        }
        .skeleton-card::after {
            content: ""; position: absolute; top: 0; right: 0; bottom: 0; left: 0;
            transform: translateX(-100%);
            background-image: linear-gradient(90deg, transparent 0, rgba(255,255,255,0.5) 50%, transparent 100%);
            animation: shimmer 1.5s infinite;
        }
        @keyframes shimmer { 100% { transform: translateX(100%); } }

        /* --- CHECKERBOARD FOR TRANSPARENT IMAGES --- */
        .checkerboard-bg {
            background-image:
                linear-gradient(45deg, #ccc 25%, transparent 25%),
                linear-gradient(-45deg, #ccc 25%, transparent 25%),
                linear-gradient(45deg, transparent 75%, #ccc 75%),
                linear-gradient(-45deg, transparent 75%, #ccc 75%);
            background-size: 20px 20px;
            background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
            background-color: white;
        }
        
        .tool-card {
            border: 1px solid #eee; background: #fff; padding: 15px; border-radius: 12px; margin-bottom: 10px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

    </style>
</head>
<body>

    <div id="proLoader" class="d-none">
        <h3 class="fw-bold mb-0" id="loaderTitle">Generating...</h3>
        <p class="text-muted small" id="loaderSub">Connecting to Neural Network...</p>
        <div class="progress-bar-container">
            <div class="progress-fill" id="loaderFill"></div>
        </div>
    </div>

    <nav class="navbar sticky-top">
        <div class="container-fluid px-4 justify-content-between">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-light border" type="button" data-bs-toggle="offcanvas" data-bs-target="#toolSidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <a class="navbar-brand" href="#"><i class="fas fa-check-circle me-2"></i>NexStock <span class="fw-light text-muted">Dev Suite</span></a>
            </div>
            
            <div class="nav-pills-custom">
                <button class="nav-btn active" id="btnImg" onclick="switchMode('image')">Photos</button>
                <button class="nav-btn" id="btnVid" onclick="switchMode('video')">Footage</button>
            </div>
        </div>
    </nav>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="toolSidebar" style="width: 380px;">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title fw-bold"><i class="fas fa-toolbox me-2"></i>Developer Toolkit</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body bg-light">
            
            <div class="tool-card border-primary border-2">
                <span class="d-block fw-bold text-primary mb-2"><i class="fas fa-robot me-2"></i>AI Image Generator</span>
                <textarea id="aiPrompt" class="form-control mb-2" rows="2" placeholder="Describe image (e.g., 'futuristic cyberpunk city')..."></textarea>
                <button onclick="generateAI()" class="btn btn-primary w-100 btn-sm fw-bold"><i class="fas fa-bolt"></i> Generate & View</button>
            </div>

            <div class="tool-card border-danger border-start border-4">
                <span class="d-block fw-bold text-danger mb-2"><i class="fas fa-eraser me-2"></i>Background Remover</span>
                <p class="small text-muted mb-2">1. Select an image from gallery.<br>2. Click button below to view transparent result.</p>
                <button onclick="removeBackground()" class="btn btn-danger w-100 btn-sm"><i class="fas fa-magic"></i> Remove BG & View</button>
            </div>

            <div class="tool-card">
                <span class="d-block fw-bold text-dark mb-2"><i class="fas fa-palette me-2"></i>Palette Extractor</span>
                <div id="colorPalette" class="d-flex gap-2 justify-content-center bg-white p-2 rounded border">
                    <span class="small text-muted fst-italic">Open image to see colors...</span>
                </div>
            </div>

            <div class="tool-card">
                 <span class="d-block fw-bold text-dark mb-2"><i class="fas fa-qrcode me-2"></i>Asset QR</span>
                 <div id="qrContainer" class="text-center p-2"></div>
                 <button onclick="generateQR()" class="btn btn-dark w-100 btn-sm">Generate QR</button>
            </div>
        </div>
    </div>

    <div class="hero text-center py-5">
        <h1 class="fw-bold mb-3">Search Global. <span style="color: var(--ai-color)">Generate AI.</span> Remove Backgrounds.</h1>
        <div style="max-width: 720px; margin: 0 auto; position: relative;">
            <input type="text" id="searchInput" class="form-control form-control-lg rounded-4 ps-4 pe-5" placeholder="Search photos, footage...">
            <button class="btn btn-dark position-absolute end-0 top-0 bottom-0 m-1 rounded-3 px-4 fw-bold" onclick="newSearch()">Search</button>
        </div>
        <div id="errorMsg" class="alert alert-danger mt-3 d-none text-start mx-auto" style="max-width: 600px;"></div>
    </div>

    <div class="container-fluid p-0">
        <div class="masonry-grid" id="gallery"></div>
    </div>

    <div class="modal fade" id="previewModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-body p-0 d-flex justify-content-center align-items-center position-relative" id="modalBodyBg" style="min-height:80vh; background: #000;">
                    <div id="modalContainer" class="w-100 text-center"></div>
                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-4 p-2 bg-white opacity-100 rounded-circle" data-bs-dismiss="modal"></button>
                </div>
                <div class="p-4 bg-white d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <div class="fw-bold text-dark fs-5" id="mUser">Creator</div>
                        <div class="text-muted small">Source: <span id="mSource" class="fw-bold"></span></div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-dark rounded-pill" onclick="copyAssetLink()"><i class="fas fa-link"></i> Link</button>
                        <button id="downloadBtn" class="btn btn-dark rounded-pill px-4 fw-bold"><i class="fas fa-download"></i> Download</button>
                        <button class="btn btn-danger rounded-pill px-3" onclick="removeBackground()"><i class="fas fa-eraser"></i> Remove BG</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <canvas id="analysisCanvas" style="display:none;"></canvas>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js"></script>

    <script>
        // CONFIG
        const KEYS = {
            pixabay: "YOUR-API-KEY", 
            pexels: "YOUR-API-KEY",
            removeBg: "YOUR-API-KEY"
        };
        const BATCH_SIZE = 4; // Keeps requests low and fast
        
        let state = { query: "", page: 1, type: "image", isLoading: false, currentItem: null };
        const gallery = document.getElementById('gallery');
        const modal = new bootstrap.Modal(document.getElementById('previewModal'));
        const loader = document.getElementById('proLoader');
        const loaderFill = document.getElementById('loaderFill');

        // --- ERROR HANDLING WRAPPER ---
        function handleMediaError(el) {
            // Hides broken images immediately so console is clean
            el.closest('.media-card').style.display = 'none';
            console.clear(); // Aggressive console cleaning
        }

        // --- LOADER LOGIC ---
        function toggleLoader(show, title="Processing", sub="Please wait...") {
            if(show) {
                document.getElementById('loaderTitle').innerText = title;
                document.getElementById('loaderSub').innerText = sub;
                loader.classList.remove('d-none');
                loaderFill.style.width = "10%";
                setTimeout(() => loaderFill.style.width = "70%", 500); // Fake progress
            } else {
                loaderFill.style.width = "100%";
                setTimeout(() => {
                    loader.classList.add('d-none');
                    loaderFill.style.width = "0%";
                }, 400);
            }
        }

        // --- 1. SEARCH LOGIC ---
        function switchMode(mode) {
            state.type = mode;
            document.getElementById('btnImg').classList.toggle('active', mode === 'image');
            document.getElementById('btnVid').classList.toggle('active', mode === 'video');
            newSearch();
        }

        function newSearch() {
            state.query = document.getElementById('searchInput').value;
            state.page = 1;
            showSkeletons();
            fetchData(true);
        }

        function showSkeletons() {
            let html = '';
            for(let i=0; i<6; i++) {
                let h = Math.floor(Math.random() * (350 - 200) + 200);
                html += `<div class="skeleton-card" style="height:${h}px"></div>`;
            }
            gallery.innerHTML = html;
        }

        async function fetchData(isNew) {
            if(state.isLoading) return;
            state.isLoading = true;

            const promises = [];
            // Pixabay
            const pbUrl = `https://pixabay.com/api/${state.type === 'video' ? 'videos/' : ''}?key=${KEYS.pixabay}&q=${encodeURIComponent(state.query)}&page=${state.page}&per_page=${BATCH_SIZE}`;
            promises.push(fetch(pbUrl).then(r=>r.json()).then(d=>({s:'pixabay', d:d.hits})).catch(()=>({s:'pixabay',d:[]})));
            
            // Pexels
            const pxUrl = `https://api.pexels.com/v1/${state.type === 'video' ? 'videos/search' : 'search'}?query=${encodeURIComponent(state.query||'nature')}&page=${state.page}&per_page=${BATCH_SIZE}`;
            promises.push(fetch(pxUrl, {headers:{Authorization:KEYS.pexels}}).then(r=>r.json()).then(d=>({s:'pexels', d:state.type==='image'?d.photos:d.videos})).catch(()=>({s:'pexels',d:[]})));

            try {
                const results = await Promise.all(promises);
                let combined = [];
                results.forEach(res => {
                    if(res.s === 'pixabay' && res.d) {
                         combined.push(...res.d.map(i => ({
                             id:'pb'+i.id, source:'Pixabay', type:state.type, user:i.user,
                             thumb: state.type==='image'?i.webformatURL:'',
                             full: state.type==='image'?i.largeImageURL:(i.videos?.large?.url||i.videos?.medium?.url),
                             vidPreview: state.type==='video'?(i.videos?.tiny?.url||i.videos?.small?.url):null
                         })));
                    }
                    if(res.s === 'pexels' && res.d) {
                         combined.push(...res.d.map(i => ({
                             id:'px'+i.id, source:'Pexels', type:state.type, user:i.user?.name||i.photographer,
                             thumb: state.type==='image'?i.src.large:i.image,
                             full: state.type==='image'?i.src.original:(i.video_files?.[0]?.link),
                             vidPreview: state.type==='video'?(i.video_files?.find(v=>v.quality==='sd')?.link||i.video_files?.[0]?.link):null
                         })));
                    }
                });

                if(isNew) gallery.innerHTML = '';
                if(combined.length === 0 && isNew) gallery.innerHTML = '<div class="text-center py-5 w-100 text-muted">No results found.</div>';
                
                // Shuffle & Render
                combined.sort(()=>Math.random()-0.5);
                renderItems(combined);
                state.page++;

            } catch(e) { console.log("Fetch error handled"); }
            finally { state.isLoading = false; }
        }

        function renderItems(items) {
            items.forEach(item => {
                const div = document.createElement('div');
                div.className = 'media-card';
                div.setAttribute('data-source', item.source);
                const badge = item.source === 'Pixabay' ? 'badge-pixabay' : 'badge-pexels';
                
                let mediaHtml = '';
                if(state.type === 'image') {
                    mediaHtml = `<img class="media-content" src="${item.thumb}" loading="lazy" onload="this.classList.add('loaded')" onerror="handleMediaError(this)">`;
                } else {
                    if(item.source === 'Pixabay') {
                         mediaHtml = `<video class="video-player" src="${item.vidPreview}" autoplay muted loop playsinline onloadeddata="this.classList.add('loaded')" onerror="handleMediaError(this)"></video>`;
                    } else {
                         // Pexels Video Hover Logic
                         mediaHtml = `<img class="media-content" src="${item.thumb}" onload="this.classList.add('loaded')" onerror="handleMediaError(this)">
                                      <div class="hover-video-container" data-vid="${item.vidPreview}"></div>`;
                    }
                }

                div.innerHTML = `
                    <span class="source-badge ${badge}">${item.source}</span>
                    ${mediaHtml}
                    <div class="meta-layer">
                        <div class="user-tag">${item.user}</div>
                        <div class="text-white"><i class="fas ${state.type==='image'?'fa-expand':'fa-play'}"></i></div>
                    </div>`;
                
                // Hover effect for Pexels Video
                if(state.type === 'video' && item.source === 'Pexels') {
                    const cont = div.querySelector('.hover-video-container');
                    div.addEventListener('mouseenter', ()=>{
                        if(!cont.innerHTML) cont.innerHTML=`<video src="${cont.dataset.vid}" autoplay muted loop style="width:100%;height:100%;object-fit:cover"></video>`;
                        else cont.querySelector('video')?.play().catch(()=>{});
                    });
                    div.addEventListener('mouseleave', ()=>cont.querySelector('video')?.pause());
                }

                div.onclick = () => openModal(item);
                gallery.appendChild(div);
            });
        }

        // --- 2. MODAL LOGIC ---
        function openModal(item, customBlobUrl = null, isTransparent = false) {
            state.currentItem = item;
            document.getElementById('mUser').innerText = item.user;
            document.getElementById('mSource').innerText = item.source;
            document.getElementById('mSource').style.color = '#333';
            
            // Set Background (Checkerboard if transparent, Black if standard)
            const bgDiv = document.getElementById('modalBodyBg');
            bgDiv.className = isTransparent ? 'modal-body p-0 d-flex justify-content-center align-items-center position-relative checkerboard-bg' : 'modal-body p-0 d-flex justify-content-center align-items-center position-relative bg-black';

            const container = document.getElementById('modalContainer');
            const urlToUse = customBlobUrl || item.full;

            // Setup Download Button
            const dlBtn = document.getElementById('downloadBtn');
            dlBtn.onclick = () => forceDownload(urlToUse, `nexstock-${Date.now()}.${state.type==='video'?'mp4':'png'}`);

            if(state.type === 'video' && !customBlobUrl) {
                container.innerHTML = `<video controls autoplay loop style="max-height:85vh; max-width:100%"><source src="${urlToUse}" type="video/mp4"></video>`;
                document.getElementById('colorPalette').innerText = "Palette N/A for Video";
            } else {
                const img = new Image();
                img.crossOrigin = "Anonymous";
                img.onload = () => extractColors(img);
                img.onerror = () => { container.innerHTML = "<p class='text-white'>Image failed to load.</p>"; };
                img.src = urlToUse;
                img.style.maxHeight = '85vh';
                img.style.maxWidth = '100%';
                container.innerHTML = '';
                container.appendChild(img);
            }
            modal.show();
        }

        // --- 3. AI GENERATION (Professional View) ---
        function generateAI() {
            const prompt = document.getElementById('aiPrompt').value.trim();
            if(!prompt) return alert("Please enter a prompt.");
            
            toggleLoader(true, "Creating Image", "AI is painting pixel by pixel...");
            
            // Safe URL encoding
            const seed = Math.floor(Math.random()*99999);
            const safePrompt = encodeURIComponent(prompt);
            const url = `https://image.pollinations.ai/prompt/${safePrompt}?seed=${seed}&nologo=true&width=1024&height=1024`;

            // Preload image
            const img = new Image();
            img.onload = () => {
                toggleLoader(false);
                // Create a fake item object for the modal
                const aiItem = {
                    id: 'ai-'+seed, source: 'AI Generated', user: 'Pollinations.ai', full: url, type: 'image'
                };
                openModal(aiItem);
            };
            img.onerror = () => {
                toggleLoader(false);
                alert("AI Server Busy (500). Try a different prompt.");
            };
            img.src = url;
        }

        // --- 4. BACKGROUND REMOVER (Professional View) ---
        async function removeBackground() {
            if(!state.currentItem || state.type === 'video') return alert("Open a photo first!");
            
            toggleLoader(true, "Removing Background", "Analyzing edges and transparency...");

            try {
                const formData = new FormData();
                formData.append('image_url', state.currentItem.full);
                formData.append('size', 'auto');
                
                const res = await fetch('https://api.remove.bg/v1.0/removebg', {
                    method: 'POST',
                    headers: { 'X-Api-Key': KEYS.removeBg },
                    body: formData
                });

                if(!res.ok) throw new Error("API Limit or Error");

                const blob = await res.blob();
                const blobUrl = URL.createObjectURL(blob);
                
                toggleLoader(false);
                
                // RE-OPEN MODAL WITH TRANSPARENT IMAGE
                // We reuse the current item metadata but swap the image URL and background style
                openModal(state.currentItem, blobUrl, true);

            } catch(e) {
                toggleLoader(false);
                alert("Error: " + e.message);
            }
        }

        // --- 5. COLOR & QR ---
        function extractColors(img) {
            try {
                const c = document.getElementById('analysisCanvas');
                const x = c.getContext('2d', { willReadFrequently: true }); // FIX FOR CONSOLE WARNING
                c.width = 100; c.height = 100;
                x.drawImage(img,0,0,100,100);
                
                // Sample 4 points
                const points = [[10,10],[50,50],[90,90],[20,80]];
                const pBox = document.getElementById('colorPalette');
                pBox.innerHTML = '';

                points.forEach(xy => {
                    const p = x.getImageData(xy[0],xy[1],1,1).data;
                    const hex = "#" + ((1<<24)+(p[0]<<16)+(p[1]<<8)+p[2]).toString(16).slice(1).toUpperCase();
                    const dot = document.createElement('div');
                    dot.style.cssText = `width:25px;height:25px;border-radius:50%;background:${hex};cursor:pointer;border:1px solid #ccc`;
                    dot.title = hex;
                    dot.onclick = () => { navigator.clipboard.writeText(hex); alert("Copied: "+hex); };
                    pBox.appendChild(dot);
                });
            } catch(e) { /* CORS error ignores */ }
        }

        function generateQR() {
            if(!state.currentItem) return alert("Open media first");
            document.getElementById('qrContainer').innerHTML = '<canvas id="qrCanvas"></canvas>';
            new QRious({element:document.getElementById('qrCanvas'), value:state.currentItem.full, size:120});
        }

        function copyAssetLink() {
            if(state.currentItem) {
                navigator.clipboard.writeText(state.currentItem.full);
                alert("Link Copied!");
            }
        }

        async function forceDownload(url, name) {
            try {
                const r = await fetch(url);
                const b = await r.blob();
                const a = document.createElement('a');
                a.href = URL.createObjectURL(b);
                a.download = name;
                a.click();
            } catch(e) { window.open(url,'_blank'); }
        }

        // SCROLL
        window.addEventListener('scroll', ()=>{
            if((window.innerHeight + window.scrollY) >= document.body.offsetHeight-500) fetchData(false);
        });
        document.getElementById('searchInput').addEventListener('keypress', e=>{ if(e.key==='Enter') newSearch(); });

        // INIT
        newSearch();

    </script>
</body>
</html>
